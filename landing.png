<!DOCTYPE html>
<!-- saved from url=(0065)https://ankitraj21805-lgtm.github.io/hirelens-ai-resume-analyzer/ -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HireLens AI | Resume Analyzer &amp; ATS Optimizer</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Inter, Arial, sans-serif;
    }

    :root {
      --bg: #020617;
      --card: rgba(15, 23, 42, 0.82);
      --border: rgba(148, 163, 184, 0.22);
      --text: #e5e7eb;
      --muted: #94a3b8;
      --blue: #38bdf8;
      --blue2: #2563eb;
      --green: #34d399;
      --yellow: #facc15;
      --red: #fb7185;
      --purple: #a78bfa;
    }

    body {
      min-height: 100vh;
      background:
        radial-gradient(circle at top left, rgba(56, 189, 248, 0.22), transparent 35%),
        radial-gradient(circle at top right, rgba(167, 139, 250, 0.18), transparent 35%),
        var(--bg);
      color: var(--text);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      width: min(1180px, 92%);
      margin: auto;
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 24px 0;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 22px;
      font-weight: 900;
    }

    .logo-icon {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 16px;
      background: rgba(56, 189, 248, 0.13);
      border: 1px solid rgba(56, 189, 248, 0.35);
      color: var(--blue);
    }

    .nav-links {
      display: flex;
      gap: 24px;
      color: var(--muted);
      font-size: 14px;
    }

    .btn {
      border: 0;
      cursor: pointer;
      border-radius: 999px;
      padding: 13px 22px;
      font-weight: 800;
      color: #020617;
      background: linear-gradient(135deg, var(--blue), #60a5fa);
      transition: 0.25s;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 18px 40px rgba(56, 189, 248, 0.24);
    }

    .btn.secondary {
      background: rgba(255, 255, 255, 0.06);
      color: var(--text);
      border: 1px solid var(--border);
    }

    .hero {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 42px;
      align-items: center;
      padding: 70px 0 45px;
    }

    .badge {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(56, 189, 248, 0.1);
      border: 1px solid rgba(56, 189, 248, 0.25);
      color: #bae6fd;
      font-size: 14px;
      margin-bottom: 20px;
    }

    h1 {
      font-size: clamp(42px, 7vw, 76px);
      line-height: 0.98;
      letter-spacing: -2.5px;
      margin-bottom: 24px;
    }

    .gradient {
      background: linear-gradient(90deg, var(--blue), #60a5fa, var(--purple));
      -webkit-background-clip: text;
      color: transparent;
    }

    .hero p {
      color: #cbd5e1;
      font-size: 18px;
      line-height: 1.8;
      max-width: 680px;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      margin-top: 30px;
      flex-wrap: wrap;
    }

    .tech {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 28px;
    }

    .chip {
      padding: 9px 13px;
      border-radius: 999px;
      color: #cbd5e1;
      background: rgba(15, 23, 42, 0.7);
      border: 1px solid var(--border);
      font-size: 13px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 26px;
      box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
      backdrop-filter: blur(18px);
    }

    .preview-score {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      margin: 26px 0;
    }

    .preview-score strong {
      font-size: 76px;
      color: var(--blue);
      line-height: 0.8;
    }

    .preview-score span {
      color: var(--muted);
      font-size: 24px;
    }

    .bar-row {
      margin: 18px 0;
    }

    .bar-info {
      display: flex;
      justify-content: space-between;
      color: #cbd5e1;
      font-size: 14px;
      margin-bottom: 8px;
    }

    .bar {
      height: 9px;
      background: #0f172a;
      border-radius: 999px;
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      width: 78%;
      background: linear-gradient(90deg, var(--blue), var(--blue2));
      border-radius: 999px;
    }

    .section {
      padding: 50px 0;
    }

    .section-title {
      margin-bottom: 26px;
    }

    .section-title small {
      color: var(--blue);
      font-weight: 800;
    }

    .section-title h2 {
      font-size: clamp(30px, 4vw, 46px);
      margin-top: 8px;
      letter-spacing: -1px;
    }

    .features {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }

    .feature {
      min-height: 190px;
    }

    .feature h3 {
      margin: 14px 0 10px;
    }

    .feature p {
      color: var(--muted);
      line-height: 1.7;
      font-size: 14px;
    }

    .analyzer {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      align-items: start;
    }

    textarea {
      width: 100%;
      min-height: 360px;
      resize: vertical;
      border-radius: 18px;
      padding: 16px;
      margin-top: 14px;
      background: rgba(2, 6, 23, 0.72);
      border: 1px solid var(--border);
      color: var(--text);
      line-height: 1.7;
      outline: none;
    }

    textarea:focus {
      border-color: rgba(56, 189, 248, 0.7);
    }

    .file-box {
      margin-top: 14px;
      border: 1px dashed rgba(148, 163, 184, 0.45);
      border-radius: 18px;
      padding: 18px;
      text-align: center;
      color: var(--muted);
      cursor: pointer;
      background: rgba(2, 6, 23, 0.42);
    }

    .file-box:hover {
      border-color: var(--blue);
      color: #e0f2fe;
    }

    .file-box input {
      display: none;
    }

    .analyze-actions {
      margin-top: 22px;
      display: flex;
      justify-content: space-between;
      gap: 14px;
      flex-wrap: wrap;
      align-items: center;
    }

    .note {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.6;
    }

    .result {
      display: none;
      grid-template-columns: 0.8fr 1.2fr;
      gap: 18px;
      margin-top: 24px;
    }

    .score-main {
      font-size: 82px;
      font-weight: 950;
      color: var(--blue);
      line-height: 0.9;
    }

    .level {
      display: inline-flex;
      margin-top: 18px;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(56, 189, 248, 0.12);
      border: 1px solid rgba(56, 189, 248, 0.25);
      color: #bae6fd;
      font-weight: 800;
    }

    .summary {
      color: #cbd5e1;
      line-height: 1.7;
      margin-top: 18px;
    }

    .report-grid {
      display: grid;
      gap: 18px;
    }

    .report-card h3 {
      margin-bottom: 14px;
    }

    .pill-wrap {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .pill {
      padding: 9px 12px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(2, 6, 23, 0.46);
      font-size: 13px;
      color: #dbeafe;
    }

    .green {
      color: var(--green);
    }

    .yellow {
      color: var(--yellow);
    }

    .red {
      color: var(--red);
    }

    .bullet {
      padding: 15px;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(2, 6, 23, 0.45);
      color: #cbd5e1;
      line-height: 1.7;
      margin-top: 10px;
      font-size: 14px;
    }

    .error {
      display: none;
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 16px;
      background: rgba(251, 113, 133, 0.12);
      border: 1px solid rgba(251, 113, 133, 0.3);
      color: #fecdd3;
    }

    .history-list {
      display: grid;
      gap: 12px;
      margin-top: 16px;
    }

    .history-item {
      padding: 14px;
      border-radius: 16px;
      background: rgba(2, 6, 23, 0.42);
      border: 1px solid var(--border);
      color: #cbd5e1;
      font-size: 14px;
      display: flex;
      justify-content: space-between;
      gap: 14px;
    }

    footer {
      padding: 42px 0;
      color: var(--muted);
      font-size: 14px;
      display: flex;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
    }

    @media (max-width: 900px) {
      .hero,
      .analyzer,
      .result {
        grid-template-columns: 1fr;
      }

      .features {
        grid-template-columns: repeat(2, 1fr);
      }

      .nav-links {
        display: none;
      }
    }

    @media (max-width: 560px) {
      .features {
        grid-template-columns: 1fr;
      }

      .btn {
        width: 100%;
      }

      .hero-actions {
        width: 100%;
      }

      .card {
        padding: 20px;
      }

      h1 {
        letter-spacing: -1.4px;
      }
    }
  </style>
</head>

<body>
  <header class="container">
    <nav class="nav">
      <a href="https://ankitraj21805-lgtm.github.io/hirelens-ai-resume-analyzer/#" class="logo">
        <span class="logo-icon">HL</span>
        <span>HireLens AI</span>
      </a>

      <div class="nav-links">
        <a href="https://ankitraj21805-lgtm.github.io/hirelens-ai-resume-analyzer/#features">Features</a>
        <a href="https://ankitraj21805-lgtm.github.io/hirelens-ai-resume-analyzer/#analyzer">Analyzer</a>
        <a href="https://ankitraj21805-lgtm.github.io/hirelens-ai-resume-analyzer/#history">History</a>
      </div>

      <a class="btn" href="https://ankitraj21805-lgtm.github.io/hirelens-ai-resume-analyzer/#analyzer">Analyze Resume</a>
    </nav>
  </header>

  <main>
    <section class="container hero">
      <div>
        <div class="badge">Recruiter-focused AI resume project</div>
        <h1>
          Build a job-ready resume with
          <span class="gradient">ATS insights.</span>
        </h1>

        <p>
          Paste your resume and job description to get an estimated ATS compatibility score,
          missing keywords, strengths, weaknesses, and improved bullet suggestions.
        </p>

        <div class="hero-actions">
          <a class="btn" href="https://ankitraj21805-lgtm.github.io/hirelens-ai-resume-analyzer/#analyzer">Start Analysis</a>
          <button class="btn secondary" onclick="loadSample()">Load Demo Data</button>
        </div>

        <div class="tech">
          <span class="chip">HTML</span>
          <span class="chip">CSS</span>
          <span class="chip">JavaScript</span>
          <span class="chip">ATS Logic</span>
          <span class="chip">Frontend MVP</span>
        </div>
      </div>

      <div class="card">
        <p class="note">Demo Report Preview</p>
        <h2>ATS Compatibility</h2>

        <div class="preview-score">
          <strong>78</strong>
          <span>/100</span>
        </div>

        <div class="bar-row">
          <div class="bar-info">
            <span>Keyword Match</span>
            <strong>32/40</strong>
          </div>
          <div class="bar"><div class="bar-fill"></div></div>
        </div>

        <div class="bar-row">
          <div class="bar-info">
            <span>Resume Structure</span>
            <strong>18/20</strong>
          </div>
          <div class="bar"><div class="bar-fill" style="width:90%"></div></div>
        </div>

        <div class="bar-row">
          <div class="bar-info">
            <span>Skills Match</span>
            <strong>20/25</strong>
          </div>
          <div class="bar"><div class="bar-fill" style="width:80%"></div></div>
        </div>

        <div class="bar-row">
          <div class="bar-info">
            <span>Impact Score</span>
            <strong>8/15</strong>
          </div>
          <div class="bar"><div class="bar-fill" style="width:54%"></div></div>
        </div>
      </div>
    </section>

    <section class="container section" id="features">
      <div class="section-title">
        <small>Features</small>
        <h2>Built like a real hiring-product MVP.</h2>
      </div>

      <div class="features">
        <div class="card feature">
          <div class="logo-icon">01</div>
          <h3>ATS-style Score</h3>
          <p>Compares resume content with a job description and generates an estimated compatibility score.</p>
        </div>

        <div class="card feature">
          <div class="logo-icon">02</div>
          <h3>Keyword Gap Analysis</h3>
          <p>Detects missing job keywords like React, TypeScript, REST API, PostgreSQL, GitHub, and more.</p>
        </div>

        <div class="card feature">
          <div class="logo-icon">03</div>
          <h3>Resume Feedback</h3>
          <p>Shows strengths, weaknesses, and practical improvement suggestions for fresher resumes.</p>
        </div>

        <div class="card feature">
          <div class="logo-icon">04</div>
          <h3>GitHub Ready</h3>
          <p>Single-file frontend MVP that can be deployed directly on GitHub Pages.</p>
        </div>
      </div>
    </section>

    <section class="container section" id="analyzer">
      <div class="section-title">
        <small>Resume Analyzer</small>
        <h2>Paste resume + job description.</h2>
      </div>

      <div class="analyzer">
        <div class="card">
          <h3>1. Resume Content</h3>
          <p class="note">Paste your resume text or upload a .txt / .md file.</p>

          <label class="file-box">
            Upload Resume Text File
            <input type="file" accept=".txt,.md" onchange="handleFileUpload(event)">
          </label>

          <textarea id="resumeText" placeholder="Paste your resume text here..."></textarea>
        </div>

        <div class="card">
          <h3>2. Job Description</h3>
          <p class="note">Paste target job description here.</p>
          <textarea id="jobText" placeholder="Paste job description here..."></textarea>
        </div>
      </div>

      <div id="errorBox" class="error"></div>

      <div class="analyze-actions">
        <p class="note">
          Note: This MVP uses transparent keyword-based scoring. Real AI API can be added in full-stack version.
        </p>

        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <button class="btn secondary" onclick="loadSample()">Load Sample</button>
          <button class="btn" onclick="analyzeResume()">Analyze Resume</button>
        </div>
      </div>

      <div class="result" id="resultBox">
        <div class="card">
          <p class="note">Estimated ATS Score</p>
          <div>
            <span class="score-main" id="scoreValue">0</span>
            <span style="font-size:26px;color:var(--muted)">/100</span>
          </div>

          <div class="level" id="scoreLevel">Good Match</div>
          <p class="summary" id="summaryText"></p>

          <div id="scoreBars"></div>

          <div style="display:flex; gap:12px; margin-top:22px; flex-wrap:wrap;">
            <button class="btn secondary" onclick="copyReport()">Copy Report</button>
            <button class="btn secondary" onclick="clearAll()">Clear</button>
          </div>
        </div>

        <div class="report-grid">
          <div class="card report-card">
            <h3 class="green">Matched Keywords</h3>
            <div class="pill-wrap" id="matchedKeywords"></div>
          </div>

          <div class="card report-card">
            <h3 class="yellow">Missing Keywords</h3>
            <div class="pill-wrap" id="missingKeywords"></div>
          </div>

          <div class="card report-card">
            <h3 class="green">Resume Strengths</h3>
            <div id="strengths"></div>
          </div>

          <div class="card report-card">
            <h3 class="red">Weaknesses To Improve</h3>
            <div id="weaknesses"></div>
          </div>

          <div class="card report-card">
            <h3>Improved Resume Bullets</h3>
            <div id="improvedBullets"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="container section" id="history">
      <div class="section-title">
        <small>Local History</small>
        <h2>Recent analysis history.</h2>
      </div>

      <div class="card">
        <p class="note">
          This demo stores analysis history in your browser only using localStorage.
        </p>
        <div class="history-list" id="historyList">
        <div class="history-item">
          <span>6/6/2026, 4:39:02 AM</span>
          <strong>67/100 — Average Match</strong>
        </div>
      </div>
      </div>
    </section>
  </main>

  <footer class="container">
    <p>© 2026 HireLens AI. Built by Ankit Sharma.</p>
    <p>Frontend MVP | Resume Analyzer | ATS Optimizer</p>
  </footer>

  <script>
    const targetKeywords = [
      "html", "css", "javascript", "typescript", "react", "react.js",
      "next.js", "nextjs", "tailwind", "tailwind css", "node.js",
      "nodejs", "express", "mongodb", "postgresql", "sql", "prisma",
      "rest api", "api", "git", "github", "responsive", "frontend",
      "backend", "full stack", "authentication", "deployment", "vercel",
      "ui", "ux", "dashboard", "performance", "testing", "agile",
      "problem solving", "database", "figma"
    ];

    const sampleResume = `Ankit Sharma
Diploma in Computer Science Engineering

Skills:
HTML, CSS, JavaScript, React.js, Next.js, Tailwind CSS, Node.js, Express.js, Git, GitHub, UI/UX

Projects:
Built a responsive developer portfolio using HTML, CSS, JavaScript and GitHub Pages.
Created a React admin dashboard with charts, reusable components, responsive layout and clean UI.
Developed frontend projects with modern layouts, mobile responsiveness and deployment.

Education:
Diploma in Computer Science Engineering`;

    const sampleJob = `We are hiring a Frontend Developer / React Developer Intern.

Required skills:
HTML, CSS, JavaScript, React.js, Next.js, TypeScript, Tailwind CSS, Git, GitHub, REST API, responsive design, frontend development, problem solving.

Good to have:
Node.js, Express.js, PostgreSQL, Prisma, deployment experience, UI/UX understanding, dashboard development, API integration.`;

    let latestReport = "";

    function normalize(text) {
      return text.toLowerCase().replace(/[^a-z0-9+#.\s-]/g, " ");
    }

    function unique(items) {
      return [...new Set(items)];
    }

    function includesKeyword(text, keyword) {
      return normalize(text).includes(normalize(keyword));
    }

    function hasAny(text, words) {
      const clean = normalize(text);
      return words.some(word => clean.includes(word));
    }

    function clamp(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    function getJobKeywords(jobText) {
      const cleanJob = normalize(jobText);
      return unique(targetKeywords.filter(keyword => cleanJob.includes(normalize(keyword))));
    }

    function loadSample() {
      document.getElementById("resumeText").value = sampleResume;
      document.getElementById("jobText").value = sampleJob;
      hideError();
      window.location.hash = "analyzer";
    }

    function handleFileUpload(event) {
      const file = event.target.files[0];
      if (!file) return;

      if (!file.name.endsWith(".txt") && !file.name.endsWith(".md")) {
        showError("For this easy MVP, upload only .txt or .md file. For PDF, copy-paste resume text manually.");
        return;
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById("resumeText").value = e.target.result;
        hideError();
      };
      reader.readAsText(file);
    }

    function analyzeResume() {
      const resumeText = document.getElementById("resumeText").value.trim();
      const jobText = document.getElementById("jobText").value.trim();

      if (resumeText.length < 80) {
        showError("Resume text is too short. Paste more resume content.");
        return;
      }

      if (jobText.length < 80) {
        showError("Job description is too short. Paste a complete job description.");
        return;
      }

      hideError();

      const requiredKeywords = getJobKeywords(jobText);
      const keywordsToCheck = requiredKeywords.length > 0 ? requiredKeywords : targetKeywords.slice(0, 16);

      const matched = keywordsToCheck.filter(keyword => includesKeyword(resumeText, keyword));
      const missing = keywordsToCheck.filter(keyword => !includesKeyword(resumeText, keyword));

      const keywordMatchScore = Math.round((matched.length / keywordsToCheck.length) * 40);

      let structureScore = 8;
      if (hasAny(resumeText, ["summary", "profile", "objective"])) structureScore += 3;
      if (hasAny(resumeText, ["skills", "technical skills"])) structureScore += 3;
      if (hasAny(resumeText, ["project", "projects"])) structureScore += 3;
      if (hasAny(resumeText, ["education", "diploma", "degree"])) structureScore += 3;
      structureScore = clamp(structureScore, 0, 20);

      const totalSkillMatches = targetKeywords.filter(keyword => includesKeyword(resumeText, keyword)).length;
      let skillsScore = Math.round((totalSkillMatches / targetKeywords.length) * 25);
      skillsScore = clamp(skillsScore, 5, 25);

      let impactScore = 4;
      if (/\d+/.test(resumeText)) impactScore += 4;
      if (hasAny(resumeText, ["built", "created", "developed", "implemented"])) impactScore += 3;
      if (hasAny(resumeText, ["deployed", "optimized", "improved", "reduced"])) impactScore += 2;
      if (hasAny(resumeText, ["github", "live", "demo", "vercel"])) impactScore += 2;
      impactScore = clamp(impactScore, 0, 15);

      const atsScore = clamp(keywordMatchScore + structureScore + skillsScore + impactScore, 0, 100);

      let level = "Needs Improvement";
      if (atsScore >= 85) level = "Excellent Match";
      else if (atsScore >= 70) level = "Good Match";
      else if (atsScore >= 50) level = "Average Match";

      const strengths = [];
      if (matched.length >= 5) strengths.push("Resume contains several relevant job description keywords.");
      if (structureScore >= 15) strengths.push("Resume has important sections like skills, projects, and education.");
      if (impactScore >= 10) strengths.push("Resume includes action verbs, measurable details, or deployment proof.");
      if (hasAny(resumeText, ["react", "next", "javascript"])) strengths.push("Frontend skills are clearly visible for React/Web Developer roles.");
      if (strengths.length === 0) strengths.push("Resume has a basic foundation but needs stronger role alignment.");

      const weaknesses = [];
      if (missing.length > 0) weaknesses.push("Some important keywords from the job description are missing.");
      if (impactScore < 9) weaknesses.push("Project bullets need more measurable impact and action verbs.");
      if (!hasAny(resumeText, ["deployed", "live", "github", "demo"])) weaknesses.push("Add GitHub/live demo links to improve recruiter trust.");
      if (!hasAny(resumeText, ["api", "backend", "database", "postgresql", "mongodb"])) weaknesses.push("Backend/database proof is weak for full-stack roles.");

      const improvedBullets = [
        "Built a responsive web application using React.js, Tailwind CSS, and JavaScript to deliver a clean user experience across mobile and desktop devices.",
        "Developed reusable UI components and structured project sections to improve maintainability, scalability, and recruiter-friendly presentation.",
        "Deployed the project using GitHub Pages or Vercel, adding live demo access, documentation, and clear setup instructions for technical evaluation."
      ];

      const summary = `Your resume is currently a ${level.toLowerCase()} for this job description. Focus on missing keywords, stronger project impact, live demo links, and role-specific bullet points.`;

      const result = {
        atsScore,
        level,
        keywordMatchScore,
        structureScore,
        skillsScore,
        impactScore,
        matched,
        missing,
        strengths,
        weaknesses,
        improvedBullets,
        summary,
        date: new Date().toLocaleString()
      };

      renderResult(result);
      saveHistory(result);
      renderHistory();
    }

    function renderResult(result) {
      document.getElementById("resultBox").style.display = "grid";
      document.getElementById("scoreValue").textContent = result.atsScore;
      document.getElementById("scoreLevel").textContent = result.level;
      document.getElementById("summaryText").textContent = result.summary;

      document.getElementById("scoreBars").innerHTML = `
        ${scoreBar("Keyword Match", result.keywordMatchScore, 40)}
        ${scoreBar("Resume Structure", result.structureScore, 20)}
        ${scoreBar("Skills Match", result.skillsScore, 25)}
        ${scoreBar("Impact Score", result.impactScore, 15)}
      `;

      renderPills("matchedKeywords", result.matched, "green");
      renderPills("missingKeywords", result.missing, "yellow");
      renderBullets("strengths", result.strengths);
      renderBullets("weaknesses", result.weaknesses);
      renderBullets("improvedBullets", result.improvedBullets);

      latestReport = `
HireLens AI Resume Analysis Report

ATS Score: ${result.atsScore}/100
Level: ${result.level}

Score Breakdown:
- Keyword Match: ${result.keywordMatchScore}/40
- Resume Structure: ${result.structureScore}/20
- Skills Match: ${result.skillsScore}/25
- Impact Score: ${result.impactScore}/15

Matched Keywords:
${result.matched.join(", ")}

Missing Keywords:
${result.missing.join(", ")}

Strengths:
${result.strengths.map(item => "- " + item).join("\n")}

Weaknesses:
${result.weaknesses.map(item => "- " + item).join("\n")}

Improved Bullets:
${result.improvedBullets.map(item => "- " + item).join("\n")}
      `.trim();

      setTimeout(() => {
        document.getElementById("resultBox").scrollIntoView({ behavior: "smooth" });
      }, 100);
    }

    function scoreBar(label, value, max) {
      const width = Math.round((value / max) * 100);
      return `
        <div class="bar-row">
          <div class="bar-info">
            <span>${label}</span>
            <strong>${value}/${max}</strong>
          </div>
          <div class="bar">
            <div class="bar-fill" style="width:${width}%"></div>
          </div>
        </div>
      `;
    }

    function renderPills(id, items, colorClass) {
      const box = document.getElementById(id);
      if (!items.length) {
        box.innerHTML = `<span class="pill">No items found</span>`;
        return;
      }

      box.innerHTML = items.map(item => `<span class="pill ${colorClass}">${item}</span>`).join("");
    }

    function renderBullets(id, items) {
      const box = document.getElementById(id);
      box.innerHTML = items.map(item => `<div class="bullet">${item}</div>`).join("");
    }

    function showError(message) {
      const errorBox = document.getElementById("errorBox");
      errorBox.textContent = message;
      errorBox.style.display = "block";
    }

    function hideError() {
      const errorBox = document.getElementById("errorBox");
      errorBox.style.display = "none";
      errorBox.textContent = "";
    }

    function copyReport() {
      if (!latestReport) {
        showError("No report available. Analyze resume first.");
        return;
      }

      navigator.clipboard.writeText(latestReport);
      alert("Report copied successfully.");
    }

    function clearAll() {
      document.getElementById("resumeText").value = "";
      document.getElementById("jobText").value = "";
      document.getElementById("resultBox").style.display = "none";
      latestReport = "";
      hideError();
    }

    function saveHistory(result) {
      const oldHistory = JSON.parse(localStorage.getItem("hirelens_history") || "[]");

      const newItem = {
        score: result.atsScore,
        level: result.level,
        date: result.date
      };

      const updated = [newItem, ...oldHistory].slice(0, 5);
      localStorage.setItem("hirelens_history", JSON.stringify(updated));
    }

    function renderHistory() {
      const list = document.getElementById("historyList");
      const history = JSON.parse(localStorage.getItem("hirelens_history") || "[]");

      if (!history.length) {
        list.innerHTML = `<p class="note">No analysis history yet. Analyze your first resume.</p>`;
        return;
      }

      list.innerHTML = history.map(item => `
        <div class="history-item">
          <span>${item.date}</span>
          <strong>${item.score}/100 — ${item.level}</strong>
        </div>
      `).join("");
    }

    renderHistory();
  </script>


</body></html>